# Required environment variables for sync-entra-access.sh
# Copy to .env.sync and fill in real values — never commit real values!

# Application (client) ID from the Entra app registration
APP_ID=

# Enterprise app (service principal) object ID
SP_OBJECT_ID=

# Optional: path to manifest (defaults to access-matrix.generated.json)
# MANIFEST=access-matrix.generated.json
