# Azure backend credentials (required when storage_backend = "azure" in .pipeline/config.json)
AZURE_STORAGE_CONNECTION_STRING=

# GitHub backend credentials (required when storage_backend = "github" in .pipeline/config.json)
GITHUB_TOKEN=
# GITHUB_OWNER=       # optional — auto-detected from git remote
# GITHUB_RUNS_REPO=   # optional — auto-detected from git remote
